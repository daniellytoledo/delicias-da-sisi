<?xml version="1.0" encoding="UTF-8"?>
<!--
  phpunit.xml — Configuração do PHPUnit para Delícias da Sisi
  Execute: ./vendor/bin/phpunit
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
         displayDetailsOnTestsThatTriggerErrors="true"
         failOnWarning="true"
         stopOnFailure="false">

  <testsuites>
    <testsuite name="Unit">
      <directory>tests/Unit</directory>
    </testsuite>
    <testsuite name="Integration">
      <directory>tests/Integration</directory>
    </testsuite>
  </testsuites>

  <source>
    <include>
      <directory>src</directory>
      <!-- Inclui os ficheiros principais se não tiver src/ -->
      <file>db.php</file>
      <file>salvar_cliente.php</file>
    </include>
  </source>

  <!-- Variáveis de ambiente para testes (usa um BD separado!) -->
  <php>
    <env name="APP_ENV"  value="testing"/>
    <env name="DB_HOST"  value="localhost"/>
    <env name="DB_NAME"  value="delicias_sisi_test"/>
    <env name="DB_USER"  value="root"/>
    <env name="DB_PASS"  value=""/>
    <env name="DB_PORT"  value="3306"/>
  </php>

</phpunit>