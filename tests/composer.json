{
  "name": "delicias-da-sisi/website",
  "description": "Site e API da Delícias da Sisi",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test":    "phpunit --testdox --colors=always",
    "test:cov": "phpunit --coverage-html coverage/"
  }
}